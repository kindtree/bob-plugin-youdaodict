{
  "identifier": "com.alex.bob.youdaodict",
  "version": "2.0.0",
  "category": "translate",
  "name": "词阶 WordTier",
  "summary": "按你的学习级别个性化的 Bob 学英语词典 + 整句翻译插件。英文完整词典 + 中文反查 + 可选 DeepSeek 翻译并按 CET/考研/雅思/托福/GRE 等级分组可点词",
  "icon": "001",
  "author": "Alex",
  "minBobVersion": "1.8.0",
  "appcast": "https://raw.githubusercontent.com/kindtree/bob-plugin-wordtier/main/appcast.json",
  "options": [
    {
      "identifier": "accent",
      "type": "menu",
      "title": "发音口音优先",
      "defaultValue": "us",
      "menuValues": [
        { "title": "美式优先", "value": "us" },
        { "title": "英式优先", "value": "uk" }
      ]
    },
    {
      "identifier": "exampleCount",
      "type": "menu",
      "title": "例句数量",
      "defaultValue": "2",
      "menuValues": [
        { "title": "1 条", "value": "1" },
        { "title": "2 条", "value": "2" },
        { "title": "3 条", "value": "3" }
      ]
    },
    {
      "identifier": "showCollins",
      "type": "menu",
      "title": "柯林斯英文释义",
      "defaultValue": "on",
      "menuValues": [
        { "title": "显示", "value": "on" },
        { "title": "隐藏", "value": "off" }
      ]
    },
    {
      "identifier": "llmProvider",
      "type": "menu",
      "title": "整句翻译服务(中文整句)",
      "defaultValue": "off",
      "menuValues": [
        { "title": "关闭(走 jsonapi 兜底)", "value": "off" },
        { "title": "DeepSeek (需 API Key)", "value": "deepseek" }
      ]
    },
    {
      "identifier": "deepseekApiKey",
      "type": "text",
      "title": "DeepSeek API Key",
      "textConfig": {
        "type": "secure",
        "placeholderText": "sk-..."
      }
    },
    {
      "identifier": "deepseekModel",
      "type": "menu",
      "title": "DeepSeek 模型",
      "defaultValue": "deepseek-chat",
      "menuValues": [
        { "title": "deepseek-chat (V3，推荐)", "value": "deepseek-chat" },
        { "title": "deepseek-reasoner (R1，推理强但慢)", "value": "deepseek-reasoner" }
      ]
    },
    {
      "identifier": "targetLevel",
      "type": "menu",
      "title": "我的目标学习级别",
      "defaultValue": "all",
      "menuValues": [
        { "title": "不偏好（显示全部）", "value": "all" },
        { "title": "小学", "value": "小学" },
        { "title": "初中", "value": "初中" },
        { "title": "高中", "value": "高中" },
        { "title": "CET4 (大学英语四级)", "value": "CET4" },
        { "title": "CET6 (大学英语六级)", "value": "CET6" },
        { "title": "考研英语", "value": "考研" },
        { "title": "雅思 IELTS", "value": "雅思" },
        { "title": "托福 TOEFL", "value": "托福" },
        { "title": "GRE", "value": "GRE" }
      ]
    },
    {
      "identifier": "levelRange",
      "type": "menu",
      "title": "可点词显示范围",
      "defaultValue": "above",
      "menuValues": [
        { "title": "目标级别及以上（默认）", "value": "above" },
        { "title": "仅目标级别", "value": "only" },
        { "title": "全部级别", "value": "all" }
      ]
    }
  ]
}
