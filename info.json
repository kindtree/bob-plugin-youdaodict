{
  "identifier": "com.alex.bob.youdaodict",
  "version": "2.1.0",
  "category": "translate",
  "name": "词阶 WordTier",
  "summary": "按你的学习级别个性化的 Bob 学英语词典 + 整句翻译插件。英文完整词典 + 中文反查 + 可选 DeepSeek 翻译并按 CET/考研/雅思/托福/GRE 等级分组可点词",
  "icon": "001",
  "author": "Alex",
  "minBobVersion": "1.8.0",
  "appcast": "https://raw.githubusercontent.com/kindtree/bob-plugin-wordtier/main/appcast.json",
  "options": [
    {
      "identifier": "accent",
      "type": "menu",
      "title": "发音口音优先",
      "defaultValue": "us",
      "menuValues": [
        { "title": "美式优先", "value": "us" },
        { "title": "英式优先", "value": "uk" }
      ]
    },
    {
      "identifier": "exampleCount",
      "type": "menu",
      "title": "例句数量",
      "defaultValue": "2",
      "menuValues": [
        { "title": "1 条", "value": "1" },
        { "title": "2 条", "value": "2" },
        { "title": "3 条", "value": "3" }
      ]
    },
    {
      "identifier": "showCollins",
      "type": "menu",
      "title": "柯林斯英文释义",
      "defaultValue": "on",
      "menuValues": [
        { "title": "显示", "value": "on" },
        { "title": "隐藏", "value": "off" }
      ]
    },
    {
      "identifier": "llmProvider",
      "type": "menu",
      "title": "整句翻译服务(中文整句)",
      "defaultValue": "off",
      "menuValues": [
        { "title": "关闭(走 jsonapi 兜底)", "value": "off" },
        { "title": "DeepSeek (需 API Key)", "value": "deepseek" }
      ]
    },
    {
      "identifier": "deepseekApiKey",
      "type": "text",
      "title": "DeepSeek API Key",
      "textConfig": {
        "type": "secure",
        "placeholderText": "sk-..."
      }
    },
    {
      "identifier": "deepseekModel",
      "type": "menu",
      "title": "模型",
      "defaultValue": "deepseek-v4-flash",
      "desc": "DeepSeek 官方 2026-04-24 升级 V4。旧别名 deepseek-chat / deepseek-reasoner 将于 2026-07-24 15:59 UTC 完全下线（官方公告 api-docs.deepseek.com/news/news260424），之后调用立即失败，请尽早切换到 v4-flash / v4-pro。选「自定义」可填任意 OpenAI 兼容模型名（见下方「自定义模型 ID」）。",
      "menuValues": [
        { "title": "deepseek-v4-flash（推荐，1M 上下文）", "value": "deepseek-v4-flash" },
        { "title": "deepseek-v4-pro（更强，价格约 3 倍）", "value": "deepseek-v4-pro" },
        { "title": "deepseek-reasoner（思考模式，2026-07-24 下线）", "value": "deepseek-reasoner" },
        { "title": "自定义（见下方）", "value": "__custom__" }
      ]
    },
    {
      "identifier": "deepseekModelCustom",
      "type": "text",
      "title": "自定义模型 ID",
      "desc": "仅当上方「模型」选「自定义」时生效。⚠️ DeepSeek 官方不接受 deepseek-v3 / deepseek-v3.2 / deepseek-r1 这类 V3/R1 字面值（从未作为公开 model id 暴露），DeepSeek 端只能填 deepseek-v4-flash / deepseek-v4-pro。第三方 OpenAI 兼容服务（搭配下方 BaseURL）可填对方文档列出的任意名，如 qwen2.5-72b-instruct、glm-4.5。",
      "textConfig": {
        "type": "visible",
        "placeholderText": "deepseek-v4-flash"
      }
    },
    {
      "identifier": "deepseekBaseUrl",
      "type": "text",
      "title": "API Base URL",
      "desc": "留空走 https://api.deepseek.com。可改为任意 OpenAI 兼容端点，如 https://api.siliconflow.cn/v1、https://ark.cn-beijing.volces.com/api/v3。填 base 即可，无需带 /chat/completions。",
      "textConfig": {
        "type": "visible",
        "placeholderText": "https://api.deepseek.com"
      }
    },
    {
      "identifier": "targetLevel",
      "type": "menu",
      "title": "我的目标学习级别",
      "defaultValue": "all",
      "menuValues": [
        { "title": "不偏好（显示全部）", "value": "all" },
        { "title": "小学", "value": "小学" },
        { "title": "初中", "value": "初中" },
        { "title": "高中", "value": "高中" },
        { "title": "CET4 (大学英语四级)", "value": "CET4" },
        { "title": "CET6 (大学英语六级)", "value": "CET6" },
        { "title": "考研英语", "value": "考研" },
        { "title": "雅思 IELTS", "value": "雅思" },
        { "title": "托福 TOEFL", "value": "托福" },
        { "title": "GRE", "value": "GRE" }
      ]
    },
    {
      "identifier": "levelRange",
      "type": "menu",
      "title": "可点词显示范围",
      "defaultValue": "above",
      "menuValues": [
        { "title": "目标级别及以上（默认）", "value": "above" },
        { "title": "仅目标级别", "value": "only" },
        { "title": "全部级别", "value": "all" }
      ]
    }
  ]
}
